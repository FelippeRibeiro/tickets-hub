{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "Tickets Hub API",
    "description": "Rotas da API tickets-hub. Variáveis: `baseUrl` (ex.: http://localhost:8080) e `token` (preenchida automaticamente após Login quando a resposta inclui `token`). Envie o cookie `token` nas requisições autenticadas.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "Topics",
      "item": [
        {
          "name": "Listar tópicos",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/topics"
          }
        },
        {
          "name": "Criar tópico (admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Cookie", "value": "token={{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Suporte técnico\"\n}"
            },
            "url": "{{baseUrl}}/api/topics"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Registrar usuário",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Maria Silva\",\n  \"email\": \"maria@example.com\",\n  \"password\": \"senha-segura\"\n}"
            },
            "url": "{{baseUrl}}/api/users"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "try {",
                  "  var data = pm.response.json();",
                  "  if (data.token) { pm.collectionVariables.set('token', data.token); }",
                  "} catch (e) {}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"maria@example.com\",\n  \"password\": \"senha-segura\"\n}"
            },
            "url": "{{baseUrl}}/api/login"
          }
        },
        {
          "name": "Me (usuário autenticado)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Cookie", "value": "token={{token}}" }],
            "url": "{{baseUrl}}/api/me"
          }
        },
        {
          "name": "Listar usuários (admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Cookie", "value": "token={{token}}" }],
            "url": "{{baseUrl}}/api/users"
          }
        }
      ]
    },
    {
      "name": "Tickets",
      "item": [
        {
          "name": "Criar ticket (não admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Cookie", "value": "token={{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Não consigo acessar\",\n  \"description\": \"Detalhes do problema...\",\n  \"topic_id\": 1\n}"
            },
            "url": "{{baseUrl}}/api/tickets"
          }
        }
      ]
    }
  ]
}
